# Mind Library Server — Environment Variables Template
# Copy this file to .env and fill in the actual values:
# cp .env.example .env

# ========== REQUIRED (Security) ==========

# Admin API Key — used for admin operations (approve instances, manage client keys, cluster management)
# MUST be set. Recommended: use a 32+ character random string
MIND_ADMIN_API_KEY=your-secure-admin-key-here

# Node-to-Node Communication Secret — all cluster nodes MUST share the same secret
# MUST be set for distributed mode, used for HMAC-SHA256 request signing (api/replica/*, api/sync/*)
MIND_NODE_SECRET=your-node-secret-here

# Client Signing Secret — used for generating client instance tokens
# MUST be changed in production to a strong random value
MIND_CLIENT_SECRET=change-me-in-production

# ========== OPTIONAL (Basic) ==========

# Data storage directory (default: /root/mind_library)
# MIND_DB_PATH=/root/mind_library

# Server bind address (default: 0.0.0.0, set to 0.0.0.0 in Docker)
# MIND_HOST=0.0.0.0

# Server port (default: 5000)
# PORT=5000

# Webhook notification URL — triggered when a new instance registers
# MIND_NOTIFICATION_WEBHOOK=https://your-webhook-endpoint.com/notify

# ========== OPTIONAL (Distributed Cluster) ==========

# Node ID — must be unique within the cluster (default: mind_hub_primary)
# MIND_NODE_ID=node-001

# Replication factor — number of nodes each data is stored on (default: 3)
# REPLICA_FACTOR=3

# Virtual nodes for consistent hash ring (affects load balancing granularity, default: 150)
# VIRTUAL_NODES=150

# Heartbeat interval in seconds (default: 30)
# HEARTBEAT_INTERVAL=30

# Failure threshold — number of consecutive heartbeat failures to mark node as down (default: 3)
# FAILURE_THRESHOLD=3

# Maximum number of thoughts to store (default: 10000)
# STORAGE_LIMIT=10000

# ========== OPTIONAL (Runtime) ==========

# Debug mode (default: false — MUST be false in production)
# DEBUG=false

# Log level: DEBUG / INFO / WARNING / ERROR (default: INFO)
# LOG_LEVEL=INFO

# JSON-formatted logs (default: false) — set to true for log aggregation systems
# LOG_JSON=false

# CORS allowed origins (comma-separated, leave empty to disable CORS)
# Example: CORS_ORIGINS=https://your-frontend.com,https://app.example.com
# CORS_ORIGINS=

# Gunicorn number of workers (leave empty for auto-detection based on CPU cores)
# GUNICORN_WORKERS=4
